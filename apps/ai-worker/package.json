{
  "name": "ai-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "uv run uvicorn src.main:app --reload --host 0.0.0.0 --port 8001",
    "start": "uv run uvicorn src.main:app --host 0.0.0.0 --port 8001",
    "lint": "uv run ruff check src tests",
    "typecheck": "uv run mypy src",
    "test": "uv run pytest",
    "clean": "rm -rf .ruff_cache .pytest_cache .mypy_cache"
  }
}
