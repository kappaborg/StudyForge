# =============================================================================
# apps/ai-worker — production env template
#
# Render → ai-worker service → Environment.
# =============================================================================

ENVIRONMENT=production
LOG_LEVEL=info

# ── audio transcription is OFF on the free deploy ───────────────────────────
# The worker would otherwise load faster-whisper (>1 GB RAM), blowing
# Render's 512 MB free-tier ceiling. With this set, audio uploads return
# a friendly "audio is disabled" error.
DISABLE_AUDIO=1

# ── database (Neon — same string as the API) ────────────────────────────────
DATABASE_URL=postgresql://USER:PASS@HOST/dbname?sslmode=require

# ── Redis (Upstash) ─────────────────────────────────────────────────────────
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# ── object storage (Cloudflare R2) ──────────────────────────────────────────
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=YOUR_R2_ACCESS_KEY_ID
S3_SECRET_KEY=YOUR_R2_SECRET_ACCESS_KEY
S3_BUCKET=studyforge-uploads

# ── embedding backend ───────────────────────────────────────────────────────
# 'fastembed' downloads BAAI/bge-small-en-v1.5 (~133 MB ONNX) on first
# request — the slow startup that follows is normal. 'stub' is the
# hash-based deterministic embedder for tests; do not use in production.
EMBEDDER_BACKEND=fastembed

# ── vector store (use Postgres pgvector — same DATABASE_URL) ────────────────
VECTOR_BACKEND=pgvector

# ── LLM provider keys (set at least one for the tutor to answer) ────────────
# Groq free tier is the most generous for chat completions.
GROQ_API_KEY=
GEMINI_API_KEY=
HF_API_KEY=
OPENROUTER_API_KEY=

# ── observability (optional) ────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
