# syntax=docker/dockerfile:1.7
#
# Notification worker for production. Built from the monorepo root
# (Render's "Docker context" stays at the repo root; "Dockerfile path"
# points at apps/notification-worker/Dockerfile).
#
# Free-tier targets: Render Background Worker. Same Prisma client as
# the api — the postinstall script reads the schema via a relative path
# (``../api/prisma/schema.prisma``), so we copy the api's prisma
# directory before ``pnpm install`` to keep the cache layer happy.

ARG NODE_VERSION=20.18.0

# ── deps + build ────────────────────────────────────────────────────────────
FROM node:${NODE_VERSION}-bookworm-slim AS build
WORKDIR /repo

RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

# Cache pnpm install by lockfile + workspace manifests.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* turbo.json tsconfig.base.json ./
COPY apps/notification-worker/package.json apps/notification-worker/package.json

# The notification-worker's ``postinstall`` runs ``prisma generate
# --schema=../api/prisma/schema.prisma`` so the api's schema must
# exist before pnpm install fires the script.
COPY apps/api/prisma apps/api/prisma

RUN pnpm install --frozen-lockfile=false --filter notification-worker...

# Now copy the rest. The Prisma client was already generated by the
# postinstall above; this step only runs the worker's tsc build.
COPY . .
RUN pnpm --filter notification-worker build

# ── runtime ─────────────────────────────────────────────────────────────────
FROM node:${NODE_VERSION}-bookworm-slim AS runtime

ENV NODE_ENV=production \
    PORT=8002

# OpenSSL for the same Prisma + Neon TLS reasons the api needs it.
RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Copy the entire built monorepo (pnpm's symlinked node_modules layout
# requires the whole tree, see apps/api/Dockerfile for the rationale).
WORKDIR /repo
COPY --from=build /repo /repo

WORKDIR /repo/apps/notification-worker

EXPOSE 8002

# Render Background Workers don't strictly need an exposed port, but
# the worker ships a small ``/health`` endpoint on PORT so a process
# supervisor (Render's free-tier liveness probe + the dispatcher's
# logs) has something to probe.
CMD ["node", "dist/main.js"]
