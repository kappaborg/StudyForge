# syntax=docker/dockerfile:1.7
#
# NestJS API for production. Built from the monorepo root (Render's
# "Docker context" stays at the repo root; "Dockerfile path" points at
# apps/api/Dockerfile).
#
# Free-tier targets: Render Web Service. Neon Postgres requires TLS, so
# the runtime image keeps OpenSSL — distroless drops it and Prisma fails
# to connect.

ARG NODE_VERSION=20.18.0

# ── deps + build ────────────────────────────────────────────────────────────
FROM node:${NODE_VERSION}-bookworm-slim AS build
WORKDIR /repo

RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

# Cache pnpm install by lockfile + workspace manifests.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* turbo.json tsconfig.base.json ./
COPY apps/api/package.json apps/api/package.json
COPY packages/shared-types/package.json packages/shared-types/package.json

# The api's ``postinstall`` runs ``prisma generate --schema=prisma/schema.prisma``
# so the schema must exist BEFORE ``pnpm install`` fires the script. Copying
# only the prisma dir (not all of apps/api) keeps the install layer
# cache-friendly: changes to TS source still hit cache, only a schema
# edit busts the install step.
COPY apps/api/prisma apps/api/prisma

RUN pnpm install --frozen-lockfile=false --filter api...

# Now copy the rest. The Prisma client was already generated by the
# postinstall above, so ``pnpm build`` doesn't need a separate generate
# step.
COPY . .
RUN pnpm --filter api build

# ── runtime ─────────────────────────────────────────────────────────────────
FROM node:${NODE_VERSION}-bookworm-slim AS runtime

ENV NODE_ENV=production \
    PORT=3001

# OpenSSL is required by Prisma at runtime when connecting to a TLS DB
# (Neon, Supabase, etc.). The slim image already ships openssl, but we
# pin ca-certificates so server cert verification works out of the box.
RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Copy the entire built monorepo. pnpm uses a symlinked node_modules
# layout where ``apps/api/node_modules/*`` are symlinks pointing into
# ``node_modules/.pnpm/<package>/node_modules/<package>`` at the repo
# root. Partial copies break those symlink targets at runtime (every
# ``require()`` fails with ENOENT), so we ship the whole tree and
# accept the slightly larger image. Free-tier image ceiling on Render
# is generous; the bottleneck is RAM, not disk.
WORKDIR /repo
COPY --from=build /repo /repo

# Run the API from its workspace directory so ``./prisma`` and the
# symlinked deps resolve the same way Prisma + Nest expect locally.
WORKDIR /repo/apps/api

EXPOSE 3001

# Render injects $PORT; Fastify (apps/api/src/main.ts) reads
# process.env.PORT and falls back to 3001 locally.
CMD ["node", "dist/main.js"]
