# =============================================================================
# apps/api — production env template
#
# Copy these into Render's "Environment" tab for the API service.
# DO NOT commit a real .env.production. Vercel + Render manage their own.
# =============================================================================

# ── runtime mode ─────────────────────────────────────────────────────────────
NODE_ENV=production
# DO NOT set AUTH_MODE=dev in production. The dev-auth plugin refuses to
# register when NODE_ENV=production anyway, but keep this unset for safety.
# AUTH_MODE=

PORT=3001
LOG_LEVEL=info

# ── database (Neon) ──────────────────────────────────────────────────────────
# Get from neon.tech → your project → Connection details. Pick the
# "Pooled connection" string and append ?pgbouncer=true&connect_timeout=10.
DATABASE_URL=postgresql://USER:PASS@HOST/dbname?sslmode=require&pgbouncer=true&connect_timeout=10

# Direct (non-pooled) URL used only by Prisma migrations. Same project,
# without pgbouncer in the path.
# DIRECT_URL=postgresql://USER:PASS@HOST/dbname?sslmode=require

# ── session cookie secret ────────────────────────────────────────────────────
# 32+ random bytes, base64. Generate with: openssl rand -base64 48
SESSION_COOKIE_SECRET=GENERATE_ME

# ── CORS — comma-separated origins the API will accept ──────────────────────
# Your Vercel deployment URL goes here. Multiple = comma-separated.
CORS_ORIGIN=https://YOUR-APP.vercel.app

# Where the API redirects browsers after the OAuth callback. Same Vercel
# URL as above (no trailing slash).
WEB_BASE_URL=https://YOUR-APP.vercel.app

# ── Google OAuth (https://console.cloud.google.com/apis/credentials) ────────
# Create an "OAuth 2.0 Client ID" of type "Web application". Authorised
# redirect URI: https://YOUR-API.onrender.com/v1/auth/google/callback
GOOGLE_CLIENT_ID=YOUR-CLIENT-ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR-CLIENT-SECRET
GOOGLE_CALLBACK_URL=https://YOUR-API.onrender.com/v1/auth/google/callback

# ── AI worker (Render service URL) ──────────────────────────────────────────
AI_WORKER_URL=https://YOUR-WORKER.onrender.com

# ── Redis (Upstash) ─────────────────────────────────────────────────────────
# Upstash → your DB → "REST API" gives an https URL. For BullMQ we need the
# "Redis URL" instead (rediss:// over TLS).
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# ── object storage (Cloudflare R2) ──────────────────────────────────────────
# R2 is S3-API-compatible. Create an API token with R2 read+write scope.
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=YOUR_R2_ACCESS_KEY_ID
S3_SECRET_KEY=YOUR_R2_SECRET_ACCESS_KEY
S3_BUCKET=studyforge-uploads
# R2 issues presigned URLs against the same endpoint; the API stitches
# them as ${S3_PUBLIC_URL}/${s3Key} when serving downloads. If you've
# attached a custom domain or made the bucket public, set this; otherwise
# leave it equal to S3_ENDPOINT.
S3_PUBLIC_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com

# ── search ───────────────────────────────────────────────────────────────────
# LEAVE EMPTY on the free-tier deploy. The search service detects this and
# falls back to a Postgres ILIKE query — slower, but no extra service.
# MEILI_HOST=
# MEILI_KEY=

# ── email (Resend) ──────────────────────────────────────────────────────────
# resend.com → API keys. The "onboarding@resend.dev" sender works without
# domain verification for development; verify a real domain before public.
RESEND_API_KEY=re_XXXXXXXXXXXX
EMAIL_FROM=StudyForge <onboarding@resend.dev>

# ── observability (optional) ────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# PRISMA_LOG=warn
