# =============================================================================
# apps/web — Vercel env template
#
# Vercel → your project → Settings → Environment Variables.
# Anything prefixed NEXT_PUBLIC_ is bundled into the client; everything
# else stays server-side.
# =============================================================================

# ── API base URL (your Render API service) ──────────────────────────────────
# No trailing slash. The web fetches /v1/* against this base.
NEXT_PUBLIC_API_BASE_URL=https://YOUR-API.onrender.com

# ── auth mode (UI hint only) ────────────────────────────────────────────────
# Tells the FE to show the Google button only and hide the email/password
# forms. Backend already enforces session auth in production regardless.
NEXT_PUBLIC_AUTH_MODE=production

# ── analytics (optional) ────────────────────────────────────────────────────
# Leave blank to disable PostHog. The wrapper no-ops cleanly when unset.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Accessibility dev banner — keep OFF in production.
# NEXT_PUBLIC_AXE_DEV=
