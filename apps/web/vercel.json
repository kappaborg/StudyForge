{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm --filter web build",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile=false",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "https://studyforge-y340.onrender.com/v1/:path*"
    },
    {
      "source": "/health",
      "destination": "https://studyforge-y340.onrender.com/health"
    },
    {
      "source": "/health/:path*",
      "destination": "https://studyforge-y340.onrender.com/health/:path*"
    }
  ]
}
