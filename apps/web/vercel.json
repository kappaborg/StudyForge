{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm --filter web build",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile=false",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./ ../../packages ../../pnpm-lock.yaml ../../package.json"
}
