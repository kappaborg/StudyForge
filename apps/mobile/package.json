{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor shell that wraps the live StudyForge web app for iOS + Android store submission.",
  "scripts": {
    "lint": "echo 'mobile lint: native projects are excluded; nothing JS to lint here' && exit 0",
    "typecheck": "tsc --noEmit",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "cap run ios",
    "cap:run:android": "cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "typescript": "^5.6.2"
  }
}
