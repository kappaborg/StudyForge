# ---------- Core ----------
NODE_ENV=development
LOG_LEVEL=info

# ---------- Database ----------
DATABASE_URL=postgresql://studyforge:studyforge@localhost:5432/studyforge?schema=public
# Direct (non-pooled) URL used by `prisma migrate`. Equal to DATABASE_URL
# for local dev; in production (Neon/Supabase) this is the unpooled
# endpoint while DATABASE_URL points at the PgBouncer pooler.
DIRECT_URL=postgresql://studyforge:studyforge@localhost:5432/studyforge?schema=public

# ---------- Redis (queues + cache) ----------
REDIS_URL=redis://localhost:6379/0

# ---------- Object storage (MinIO dev / S3 prod) ----------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=studyforge
S3_SECRET_KEY=studyforge-dev-secret
S3_BUCKET=studyforge-uploads
S3_FORCE_PATH_STYLE=true

# ---------- Auth ----------
# AUTH_MODE=dev enables the x-tenant-id / x-user-id header shortcut. In prod
# this var is unset and the real OAuth flow registers its own pre-handler.
AUTH_MODE=dev
JWT_SECRET=replace-me-with-32+char-random
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---------- BYOK (envelope encryption) ----------
# 32-byte KEK, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# In production this comes from KMS / Vault, never from env.
STUDYFORGE_KEK_BASE64=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ---------- LLM Providers (free-tier first) ----------
GROQ_API_KEY=
GEMINI_API_KEY=
HF_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ---------- LLM Providers (paid fallback / BYOK / Pro) ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- Search ----------
MEILI_HOST=http://localhost:7700
MEILI_KEY=studyforge-meili-master

# ---------- Vector store ----------
VECTOR_BACKEND=chroma
CHROMA_URL=http://localhost:8000
PINECONE_API_KEY=
PINECONE_INDEX=

# ---------- Observability ----------
SENTRY_DSN=
POSTHOG_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ---------- Feature flags ----------
UNLEASH_URL=http://localhost:4242/api
UNLEASH_TOKEN=

# ---------- Frontend (public) ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:3001
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=
